{
  "name": "@tsfpp/agents",
  "version": "2.0.0",
  "description": "Workspace AI tooling for TSF++ projects: universal ai sources, generated compatibility output, and reusable prompts",
  "keywords": [
    "tsfpp",
    "copilot",
    "ai",
    "agents",
    "instructions",
    "claude",
    "functional",
    "typescript"
  ],
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/tsfpp/agents#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/tsfpp/agents.git"
  },
  "bugs": {
    "url": "https://github.com/tsfpp/agents/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "tsfpp-agents": "./init.mjs",
    "tsfpp-bootstrap": "./bin/bootstrap.sh"
  },
  "files": [
    "bin/",
    "scripts/",
    "ai.md",
    "ai/",
    "init.mjs",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "@tsfpp/standard":     ">=1.3.0",
    "@tsfpp/prelude":      ">=2.0.0",
    "@tsfpp/boundary":     ">=2.0.0",
    "@tsfpp/eslint-config":">=1.0.0",
    "@tsfpp/tsconfig":     ">=1.0.0",
    "@tsfpp/mcp-server":   ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@tsfpp/mcp-server": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
