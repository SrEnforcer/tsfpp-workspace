{
  "name": "@tsfpp/boundary",
  "version": "2.0.1",
  "description": "Functional HTTP boundary toolkit with typed handler helpers, Problem Details mapping, pagination, idempotency, and webhook primitives",
  "private": false,
  "license": "MIT",
  "type": "module",
  "keywords": [
    "typescript",
    "functional-programming",
    "http",
    "api",
    "boundary",
    "result",
    "error-handling",
    "response-builders",
    "zod",
    "hexagonal-architecture",
    "tsfpp"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepack": "pnpm run build",
    "prepublishOnly": "pnpm run typecheck && pnpm run test"
  },
  "files": [
    "dist",
    "README.md",
    "RECIPES.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "homepage": "https://github.com/tsfpp/boundary#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/tsfpp/boundary.git"
  },
  "bugs": {
    "url": "https://github.com/tsfpp/boundary/issues"
  },
  "dependencies": {
    "@tsfpp/prelude": "2.0.1"
  },
  "devDependencies": {
    "@tsfpp/agents": "^2.0.1",
    "@tsfpp/eslint-config": "^1.0.2",
    "@tsfpp/standard": "^1.4.0",
    "@tsfpp/tsconfig": "^1.0.0",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.4",
    "eslint-plugin-functional": "^9.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "main": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
