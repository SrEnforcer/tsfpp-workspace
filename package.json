{
  "name": "@tsfpp/prelude",
  "version": "1.7.0",
  "description": "Functional prelude for TypeScript with Option, Result, and core combinators",
  "private": false,
  "license": "MIT",
  "type": "module",
  "keywords": [
    "typescript",
    "functional-programming",
    "algebraic-data-types",
    "option",
    "result",
    "pipe",
    "branded-types",
    "immutable",
    "tsfpp",
    "zero-dependencies"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepack": "pnpm run build",
    "prepublishOnly": "pnpm run typecheck && pnpm run test"
  },
  "files": [
    "dist",
    "README.md",
    "RECIPES.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "homepage": "https://github.com/tsfpp/prelude#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/tsfpp/prelude.git"
  },
  "bugs": {
    "url": "https://github.com/tsfpp/prelude/issues"
  },
  "devDependencies": {
    "@tsfpp/eslint-config": "^1.0.1",
    "@tsfpp/tsconfig": "^1.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.0.0",
    "eslint-plugin-functional": "^9.0.4",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  },
  "main": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
