{
  "name": "@tsfpp/prelude",
  "version": "1.0.0",
  "description": "TSF++ functional prelude with Option, Result, and core combinators",
  "private": false,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "files": [
    "src",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "ramda": "^0.30.1"
  },
  "devDependencies": {
    "@tsfpp/eslint-config": "workspace:*",
    "@tsfpp/tsconfig": "workspace:*",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@types/ramda": "^0.30.2",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.0.0",
    "eslint-plugin-functional": "^7.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  },
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./ramda": "./src/ramda.ts"
  }
}
