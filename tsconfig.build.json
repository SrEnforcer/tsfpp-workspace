{
  "compilerOptions": {
    "target":               "ES2022",
    "module":               "ESNext",
    "moduleResolution":     "Bundler",
    "verbatimModuleSyntax": true,
    "declaration":          true,
    "declarationMap":       true,
    "sourceMap":            true,
    "outDir":               "dist",
    "strict":               true,
    "skipLibCheck":         true
  },
  "include": [
    "declarations.d.ts",
    "plugin-compat.ts",
    "base.ts",
    "react.ts",
    "api.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}